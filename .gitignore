# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/
.env*.local

# data pipeline intermediates (generated by scripts/, not part of app)
scripts/chunks/
scripts/*-progress.json
scripts/pending-*.json
scripts/photos-*-results.json
scripts/photos-*-verified.json
scripts/photos-*-high-conf.json
scripts/photos-serper-review.html
scripts/korean-names-extracted.json
scripts/forbes-placeholder-ids.json
scripts/missing-photos.txt
scripts/cleanup-test-emails.ts
public/photos-review.html
